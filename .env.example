# ══════════════════════════════════════════════════
# FIFA World Cup Bot v5 — Environment Variables
# NO CREDIT CARD REQUIRED for any of these
# ══════════════════════════════════════════════════

# ── AI: Google Gemini (FREE) ──────────────────────
# 1. Go to https://aistudio.google.com
# 2. Click "Get API key" → Create API key
# 3. Copy and paste below
GEMINI_API_KEY=your_gemini_api_key_here

# ── Publishing: Zernio (FREE tier) ───────────────
# 1. Go to https://zernio.com → Sign up (no card)
# 2. Connect your YouTube channel → copy Account ID
# 3. Connect your TikTok → copy Account ID  (optional)
# 4. Connect your Twitter → copy Account ID (optional)
# 5. Dashboard → API Keys → copy your key
ZERNIO_API_KEY=your_zernio_api_key_here
ZERNIO_YOUTUBE_ACCOUNT_ID=acc_xxxxxxxxxxxxxxxx
ZERNIO_TIKTOK_ACCOUNT_ID=acc_xxxxxxxxxxxxxxxx
ZERNIO_TWITTER_ACCOUNT_ID=acc_xxxxxxxxxxxxxxxx

# ── Match Data: api-football.com (FREE) ──────────
# 1. Go to https://www.api-football.com → Sign up
# 2. Dashboard → copy your API key
FOOTBALL_API_KEY=your_football_api_key_here
FOOTBALL_LEAGUE_ID=1
FOOTBALL_SEASON=2026

# ── Optional ──────────────────────────────────────
CHANNEL_NAME=your_youtube_channel_handle
DRY_RUN=false
